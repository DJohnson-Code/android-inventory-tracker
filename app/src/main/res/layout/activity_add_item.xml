<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textAddItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Inventory Item"
            android:textColor="#1F2933"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item Details"
                android:textColor="#1F2933"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Item Name"
                android:inputType="text"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/editQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Quantity"
                android:inputType="number"
                android:minHeight="48dp" />

            <EditText
                android:id="@+id/editLocationDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Location/Description"
                android:inputType="text"
                android:minHeight="48dp" />

            <Button
                android:id="@+id/buttonSaveItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2F5D50"
                android:onClick="saveItem"
                android:text="Save Item"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#6B7280"
                android:onClick="returnToInventory"
                android:text="Cancel"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/textSmsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SMS Inventory Alerts"
                android:textColor="#1F2933"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSmsExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="This app can send a text alert when an item reaches zero."
                android:textColor="#4B5563"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/editPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone Number for Alerts"
                android:inputType="phone"
                android:minHeight="48dp" />

            <Button
                android:id="@+id/buttonEnableSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#2F5D50"
                android:onClick="enableSmsAlerts"
                android:text="Enable SMS Alerts"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/buttonNotNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#6B7280"
                android:onClick="declineSmsAlerts"
                android:text="Not Now"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/textSmsStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="SMS alerts are off"
                android:textColor="#4B5563"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
